{
    "extends": "@repo/typescript-config/react-library.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "types": ["vite/client"]
    },
    "include": ["src", "auto-imports.d.ts"]
}
